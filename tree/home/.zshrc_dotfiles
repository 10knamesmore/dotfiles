# dots 管理的 zsh 主配置（Oh My Zsh 已退役，模块在 ~/.config/zsh/*.zsh）。
# 改主配置改 tree/home/.zshrc_dotfiles；平台差异改 .zshrc_linux/.zshrc_macos。

# dots 注入：DOTFILES_DIR / DOTS_SCRIPTS / PATH（替代旧 *_TEMPLATE 模板变量）
source "$HOME/.config/dots/env.zsh"

export EDITOR="nvim"
export KITTY_SHELL_INTEGRATION="enabled no-cursor"

# 跳转（别名主体在 ~/.config/zsh/40-aliases.zsh）
alias dot="cd $DOTFILES_DIR"
alias skill="cd $DOTFILES_DIR/tree/home/.agents/skills"

# PATH
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# zsh 模块（历史/目录/补全/键绑定 + 内联函数 + 历史建议）。compinit 在 10-options 跑，须在 uv 补全前。
source "$HOME/.config/zsh/10-options.zsh"
source "$HOME/.config/zsh/20-functions.zsh"
source "$HOME/.config/zsh/30-autosuggestions.zsh"
source "$HOME/.config/zsh/40-aliases.zsh"

# 平台差异
if [[ -f "$HOME/.zshrc_linux" ]]; then
    source "$HOME/.zshrc_linux"
elif [[ -f "$HOME/.zshrc_macos" ]]; then
    source "$HOME/.zshrc_macos"
fi

# 工具初始化（均加 command -v 守卫，缺失不报错——便于换机）
command -v uv >/dev/null && eval "$(uv generate-shell-completion zsh)"
proxy
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"   # 替代旧 OMZ z 插件
# 补全覆盖：`z 词<Tab>` 直接进 fzf（默认要「空格+Tab」才进，词贴着光标时只补本地子目录）。
# init 已 compdef z → __zoxide_z_complete，重定义函数体即可生效；选中后由 init 的 helper 直接跳转。
if command -v zoxide >/dev/null; then
    function __zoxide_z_complete() {
        [[ "${#words[@]}" -eq "${CURRENT}" ]] || return 0  # 仅在光标位于行尾时补全
        __zoxide_result="$(\command zoxide query --exclude "$(__zoxide_pwd || \builtin true)" --interactive -- ${words[2,-1]})" || __zoxide_result=''
        compadd -Q ""                                       # 占位，阻止补全系统继续走其他 completer
        \builtin bindkey '\e[0n' '__zoxide_z_complete_helper'
        \builtin printf '\e[5n'                             # 触发 helper：拿 __zoxide_result 回填并 accept-line
        return 0
    }
fi
command -v fzf >/dev/null && source <(fzf --zsh)            # Ctrl-R 模糊历史 / Ctrl-T 文件 / Alt-C cd
command -v starship >/dev/null && eval "$(starship init zsh)"

# transient prompt：命令被接受后简化历史行的提示符
zle-line-init() {
    emulate -L zsh
    [[ $CONTEXT == start ]] || return 0

    while true; do
        zle .recursive-edit
        local -i ret=$?
        [[ $ret == 0 && $KEYS == $'\4' ]] || break
        [[ -o ignore_eof ]] || exit 0
    done

    local saved_prompt=$PROMPT
    local saved_rprompt=$RPROMPT
    PROMPT="$(starship prompt --profile transient)"
    # starship 的 rtransient 有 bug 不能显示，RPROMPT 硬编码 catppuccin lavender
    RPROMPT=$'%{\e[38;2;180;190;254m%}[ %~]%{\e[0m%}'
    zle .reset-prompt
    PROMPT=$saved_prompt
    RPROMPT=$saved_rprompt

    if ((ret)); then
        zle .send-break
    else
        zle .accept-line
    fi
    return ret
}
zle -N zle-line-init

# 语法高亮必须最后 source（包裹所有已定义 widget）
source "$HOME/.config/zsh/90-syntax-highlighting.zsh"
