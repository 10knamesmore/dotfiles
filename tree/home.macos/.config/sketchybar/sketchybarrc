window_title=(
  icon=󰘔
  icon.color="$MAUVE"
  label.color="$MAUVE"
  label.max_chars=52
  scroll_texts=off
  background.color="$MANTLE"
  update_freq=2
  script="$PLUGIN_DIR/window.sh"
)
sketchybar --add item window_title left \
           --set window_title "${window_title[@]}" \
           --subscribe window_title front_app_switched window_focus space_change

net_up=(
  icon=󰕒
  icon.color="$GREEN"
  label.color="$GREEN"
  update_freq=1
  script="$PLUGIN_DIR/netspeed.sh up"
)
sketchybar --add item net_up center \
           --set net_up "${net_up[@]}"

clock=(
  icon=
  icon.color="$BASE"
  label.color="$BASE"
  background.color="$BLUE"
  background.height=26
  background.corner_radius=16
  popup.background.color="$MANTLE"
  popup.background.corner_radius=12
  popup.blur_radius=16
  update_freq=1
  script="$PLUGIN_DIR/clock.sh"
)
sketchybar --add item clock center \
           --set clock "${clock[@]}" \
           --subscribe clock mouse.entered mouse.exited mouse.exited.global

clock_details=(
  icon.drawing=off
  label.width=160
  label.align=center
  label.padding_left=12
  label.padding_right=12
  background.drawing=off
)
sketchybar --add item clock.details.date popup.clock \
           --set clock.details.date "${clock_details[@]}" \
                                     label.color="$TEXT" \
                                     label.font="Hack Nerd Font:Bold:14.0"

sketchybar --add item clock.details.weekday popup.clock \
           --set clock.details.weekday "${clock_details[@]}" \
                                        label.color="$BLUE"

net_down=(
  icon=󰇚
  icon.color="$SKY"
  label.color="$SKY"
  update_freq=1
  script="$PLUGIN_DIR/netspeed.sh down"
)
sketchybar --add item net_down center \
           --set net_down "${net_down[@]}"

cpu=(
  icon=
  icon.color="$BLUE"
  label.color="$BLUE"
  update_freq=2
  script="$PLUGIN_DIR/cpu.sh"
)
sketchybar --add item cpu right \
           --set cpu "${cpu[@]}"

memory=(
  icon=
  icon.color="$MAUVE"
  label.color="$MAUVE"
  popup.background.color="$MANTLE"
  popup.background.corner_radius=12
  popup.blur_radius=16
  update_freq=3
  script="$PLUGIN_DIR/memory.sh"
)
sketchybar --add item memory right \
           --set memory "${memory[@]}" \
           --subscribe memory mouse.entered mouse.exited mouse.exited.global

memory_details_common=(
  icon.drawing=off
  label.width=200
  label.align=left
  label.padding_left=12
  label.padding_right=12
  background.drawing=off
)

memory_details_title=(
  "${memory_details_common[@]}"
  label.color="$MAUVE"
  label.font="Hack Nerd Font:Bold:14.0"
)
sketchybar --add item memory.details.title popup.memory \
           --set memory.details.title "${memory_details_title[@]}"

sketchybar --add item memory.details.used popup.memory \
           --set memory.details.used "${memory_details_common[@]}" \
                                     label.color="$TEXT"

sketchybar --add item memory.details.cached popup.memory \
           --set memory.details.cached "${memory_details_common[@]}" \
                                       label.color="$TEXT"

sketchybar --add item memory.details.compressed popup.memory \
           --set memory.details.compressed "${memory_details_common[@]}" \
                                           label.color="$TEXT"

sketchybar --add item memory.details.swap popup.memory \
           --set memory.details.swap "${memory_details_common[@]}" \
                                     label.color="$TEXT"

