volume=(
  icon.color="$PEACH"
  label.color="$PEACH"
  script="$PLUGIN_DIR/volume.sh"
)
sketchybar --add item volume right \
           --set volume "${volume[@]}" \
           --subscribe volume volume_change

network=(
  icon=󰖩
  icon.color="$SKY"
  label.color="$SKY"
  label.max_chars=24
  popup.background.color="$MANTLE"
  popup.background.corner_radius=12
  popup.blur_radius=16
  update_freq=10
  script="$PLUGIN_DIR/network.sh"
)
sketchybar --add item network right \
           --set network "${network[@]}" \
           --subscribe network mouse.entered mouse.exited mouse.exited.global

network_details_common=(
  icon.drawing=off
  label.max_chars=120
  label.width=240
  label.align=left
  label.padding_left=12
  label.padding_right=12
  label.color="$TEXT"
  background.drawing=off
)

network_details_title=(
  "${network_details_common[@]}"
  label.color="$SKY"
  label.font="Hack Nerd Font:Bold:14.0"
)
sketchybar --add item network.details.title popup.network \
           --set network.details.title "${network_details_title[@]}"

sketchybar --add item network.details.interface popup.network \
           --set network.details.interface "${network_details_common[@]}"

sketchybar --add item network.details.ip popup.network \
           --set network.details.ip "${network_details_common[@]}"

sketchybar --add item network.details.gateway popup.network \
           --set network.details.gateway "${network_details_common[@]}"

sketchybar --add item network.details.dns popup.network \
           --set network.details.dns "${network_details_common[@]}"

battery=(
  icon.color="$GREEN"
  label.color="$GREEN"
  update_freq=10
  script="$PLUGIN_DIR/battery.sh"
)
sketchybar --add item battery right \
           --set battery "${battery[@]}" \
           --subscribe battery system_woke power_source_change

sketchybar --add bracket workspaces '/space\..*/' layout \
           --set workspaces background.color="$BASE" \
                            background.corner_radius=16 \
                            background.height=28

sketchybar --update
