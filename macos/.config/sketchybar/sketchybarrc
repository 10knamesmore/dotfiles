window_title=(
  icon=󰘔
  icon.color="$MAUVE"
  label.color="$MAUVE"
  label.max_chars=52
  scroll_texts=off
  background.color="$MANTLE"
  update_freq=2
  script="$PLUGIN_DIR/window.sh"
)
sketchybar --add item window_title left \
           --set window_title "${window_title[@]}" \
           --subscribe window_title front_app_switched window_focus space_change

net_up=(
  icon=󰕒
  icon.color="$GREEN"
  label.color="$GREEN"
  update_freq=1
  script="$PLUGIN_DIR/netspeed.sh up"
)
sketchybar --add item net_up center \
           --set net_up "${net_up[@]}"

clock=(
  icon=
  icon.color="$BASE"
  label.color="$BASE"
  background.color="$BLUE"
  background.height=26
  background.corner_radius=16
  update_freq=1
  script="$PLUGIN_DIR/clock.sh"
)
sketchybar --add item clock center \
           --set clock "${clock[@]}"

net_down=(
  icon=󰇚
  icon.color="$SKY"
  label.color="$SKY"
  update_freq=1
  script="$PLUGIN_DIR/netspeed.sh down"
)
sketchybar --add item net_down center \
           --set net_down "${net_down[@]}"

cpu=(
  icon=
  icon.color="$BLUE"
  label.color="$BLUE"
  update_freq=2
  script="$PLUGIN_DIR/cpu.sh"
)
sketchybar --add item cpu right \
           --set cpu "${cpu[@]}"

memory=(
  icon=
  icon.color="$MAUVE"
  label.color="$MAUVE"
  update_freq=3
  script="$PLUGIN_DIR/memory.sh"
)
sketchybar --add item memory right \
           --set memory "${memory[@]}"

