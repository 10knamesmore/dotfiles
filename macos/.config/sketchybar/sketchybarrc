volume=(
  icon.color="$PEACH"
  label.color="$PEACH"
  script="$PLUGIN_DIR/volume.sh"
)
sketchybar --add item volume right \
           --set volume "${volume[@]}" \
           --subscribe volume volume_change

network=(
  icon=󰖩
  icon.color="$SKY"
  label.color="$SKY"
  label.max_chars=24
  update_freq=10
  script="$PLUGIN_DIR/network.sh"
)
sketchybar --add item network right \
           --set network "${network[@]}"

battery=(
  icon.color="$GREEN"
  label.color="$GREEN"
  update_freq=10
  script="$PLUGIN_DIR/battery.sh"
)
sketchybar --add item battery right \
           --set battery "${battery[@]}" \
           --subscribe battery system_woke power_source_change

sketchybar --add bracket workspaces '/space\..*/' layout \
           --set workspaces background.color="$BASE" \
                            background.corner_radius=16 \
                            background.height=28

sketchybar --update
